# Kimai MCP Streamable HTTP Server Configuration
# Copy this file to .env and fill in your values
#
# This configures the kimai-mcp-streamable server (Claude.ai Connectors).
# The SSE server (kimai-mcp-server) is DEPRECATED and non-functional.

# =============================================================================
# REQUIRED: Users configuration
# =============================================================================

# Path to users.json (per-user Kimai credentials + OAuth auth_secret)
# See config/users.example.json for the format
# USERS_CONFIG_FILE=/app/config/users.json

# Alternative to users.json: configure users via environment variables
# KIMAI_USER_<SLUG>_URL=https://kimai.example.com
# KIMAI_USER_<SLUG>_TOKEN=kimai-api-token
# KIMAI_USER_<SLUG>_AUTH_SECRET=long-random-oauth-login-secret

# =============================================================================
# OAuth 2.1 (recommended way to connect Claude.ai)
# =============================================================================

# Public base URL of this server = OAuth issuer.
# REQUIRED behind a reverse proxy; must be HTTPS (except localhost).
# KIMAI_MCP_PUBLIC_URL=https://mcp.example.com

# Persist registered OAuth clients across restarts (optional)
# KIMAI_MCP_OAUTH_STATE_FILE=/app/config/oauth_clients.json

# Disable the deprecated /mcp/{slug} endpoints (recommended once OAuth works)
# KIMAI_MCP_DISABLE_LEGACY_SLUGS=true

# =============================================================================
# Security
# =============================================================================

# Only trust X-Forwarded-For / X-Real-IP from these peers (comma-separated).
# Set this to your reverse proxy IP(s); otherwise the direct peer IP is used.
# KIMAI_MCP_TRUSTED_PROXIES=127.0.0.1

# Requests per minute per IP (default: 60, 0 to disable)
# RATE_LIMIT_RPM=60

# =============================================================================
# SSL/TLS for Kimai connections
# =============================================================================

# Options: true (default), false, or path to CA certificate file
# KIMAI_SSL_VERIFY=true
# KIMAI_SSL_VERIFY=/app/certs/ca-bundle.crt

# =============================================================================
# Server binding
# =============================================================================

# Port to expose the server on (default: 8000)
# SERVER_PORT=8000
